{
  "expo": {
    "name": "Walccy",
    "slug": "walccy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.walccy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/notification-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "dev.walccy.app",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Walccy to use your camera to scan QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Walccy needs access to your photos to attach images to chat.",
          "cameraPermission": "Walccy needs camera access to attach photos to chat."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7B61FF"
        }
      ],
      "expo-font"
    ],
    "scheme": "walccy",
    "experiments": {
      "typedRoutes": true
    }
  }
}
